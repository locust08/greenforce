---
import WebflowPage from '../../components/WebflowPage.astro';
import generalManager from '../../raw/job-positions/general-manager.html?raw';
import humanResourcesManager from '../../raw/job-positions/human-resources-manager.html?raw';
import marketingManager from '../../raw/job-positions/marketing-manager.html?raw';
import operationsManager from '../../raw/job-positions/operations-manager.html?raw';
import projectManager from '../../raw/job-positions/project-manager.html?raw';
import salesManager from '../../raw/job-positions/sales-manager.html?raw';

const pages: Record<string, string> = {
  'general-manager': generalManager,
  'human-resources-manager': humanResourcesManager,
  'marketing-manager': marketingManager,
  'operations-manager': operationsManager,
  'project-manager': projectManager,
  'sales-manager': salesManager,
};

export function getStaticPaths() {
  return [
    'general-manager',
    'human-resources-manager',
    'marketing-manager',
    'operations-manager',
    'project-manager',
    'sales-manager',
  ].map((slug) => ({ params: { slug } }));
}

const html = pages[Astro.params.slug ?? ''];
---

<WebflowPage html={html} />
