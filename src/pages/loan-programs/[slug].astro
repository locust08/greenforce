---
import WebflowPage from '../../components/WebflowPage.astro';
import fhaLoans from '../../raw/loan-programs/fha-loans.html?raw';
import fixedRateMortgages from '../../raw/loan-programs/fixed-rate-mortgages.html?raw';
import flexibleMortgages from '../../raw/loan-programs/flexible-mortgages.html?raw';
import jumboLoans from '../../raw/loan-programs/jumbo-loans.html?raw';
import refinancingOptions from '../../raw/loan-programs/refinancing-options.html?raw';
import vaLoans from '../../raw/loan-programs/va-loans.html?raw';

const pages: Record<string, string> = {
  'fha-loans': fhaLoans,
  'fixed-rate-mortgages': fixedRateMortgages,
  'flexible-mortgages': flexibleMortgages,
  'jumbo-loans': jumboLoans,
  'refinancing-options': refinancingOptions,
  'va-loans': vaLoans,
};

export function getStaticPaths() {
  return [
    'fha-loans',
    'fixed-rate-mortgages',
    'flexible-mortgages',
    'jumbo-loans',
    'refinancing-options',
    'va-loans',
  ].map((slug) => ({ params: { slug } }));
}

const html = pages[Astro.params.slug ?? ''];
---

<WebflowPage html={html} />
