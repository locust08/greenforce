---
import WebflowPage from '../../components/WebflowPage.astro';
import financialInsights from '../../raw/posts-categories/financial-insights.html?raw';
import homebuyerTips from '../../raw/posts-categories/homebuyer-tips.html?raw';
import mortgageBasics from '../../raw/posts-categories/mortgage-basics.html?raw';

const pages: Record<string, string> = {
  'financial-insights': financialInsights,
  'homebuyer-tips': homebuyerTips,
  'mortgage-basics': mortgageBasics,
};

export function getStaticPaths() {
  return [
    'financial-insights',
    'homebuyer-tips',
    'mortgage-basics',
  ].map((slug) => ({ params: { slug } }));
}

const html = pages[Astro.params.slug ?? ''];
---

<WebflowPage html={html} />
