---
import WebflowPage from '../../components/WebflowPage.astro';
import boostCreditScore from '../../raw/blog-posts/boost-your-credit-score-before-applying-for-a-loan.html?raw';
import fixedVsAdjustable from '../../raw/blog-posts/fixed-vs-adjustable-rate-mortgages.html?raw';
import firstTimeHomebuyer from '../../raw/blog-posts/first-time-homebuyer-mistakes-to-avoid.html?raw';
import preApprovalGuide from '../../raw/blog-posts/guide-to-getting-pre-approved-for-a-mortgage.html?raw';
import refinancingSavings from '../../raw/blog-posts/how-refinancing-can-save-you-thousands.html?raw';
import lowFixedRate from '../../raw/blog-posts/the-benefits-of-locking-in-a-low-fixed-rate.html?raw';
import firstStepDreamHome from '../../raw/blog-posts/the-first-step-toward-owning-your-dream-home.html?raw';

const pages: Record<string, string> = {
  'boost-your-credit-score-before-applying-for-a-loan': boostCreditScore,
  'fixed-vs-adjustable-rate-mortgages': fixedVsAdjustable,
  'first-time-homebuyer-mistakes-to-avoid': firstTimeHomebuyer,
  'guide-to-getting-pre-approved-for-a-mortgage': preApprovalGuide,
  'how-refinancing-can-save-you-thousands': refinancingSavings,
  'the-benefits-of-locking-in-a-low-fixed-rate': lowFixedRate,
  'the-first-step-toward-owning-your-dream-home': firstStepDreamHome,
};

export function getStaticPaths() {
  return [
    'boost-your-credit-score-before-applying-for-a-loan',
    'fixed-vs-adjustable-rate-mortgages',
    'first-time-homebuyer-mistakes-to-avoid',
    'guide-to-getting-pre-approved-for-a-mortgage',
    'how-refinancing-can-save-you-thousands',
    'the-benefits-of-locking-in-a-low-fixed-rate',
    'the-first-step-toward-owning-your-dream-home',
  ].map((slug) => ({ params: { slug } }));
}

const html = pages[Astro.params.slug ?? ''];
---

<WebflowPage html={html} />
