---
import WebflowPage from '../../components/WebflowPage.astro';
import arleneMccoy from '../../raw/team/arlene-mccoy.html?raw';
import brookSeims from '../../raw/team/brook-seims.html?raw';
import guyHawkins from '../../raw/team/guy-hawkins.html?raw';
import kiraZayn from '../../raw/team/kira-zayn.html?raw';
import theresaWebb from '../../raw/team/theresa-webb.html?raw';
import traiceDantini from '../../raw/team/traice-dantini.html?raw';

const pages: Record<string, string> = {
  'arlene-mccoy': arleneMccoy,
  'brook-seims': brookSeims,
  'guy-hawkins': guyHawkins,
  'kira-zayn': kiraZayn,
  'theresa-webb': theresaWebb,
  'traice-dantini': traiceDantini,
};

export function getStaticPaths() {
  return [
    'arlene-mccoy',
    'brook-seims',
    'guy-hawkins',
    'kira-zayn',
    'theresa-webb',
    'traice-dantini',
  ].map((slug) => ({ params: { slug } }));
}

const html = pages[Astro.params.slug ?? ''];
---

<WebflowPage html={html} />
