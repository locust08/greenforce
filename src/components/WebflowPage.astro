const templatePromotionCleanupScript = `
  <script>
    (() => {
      const selectors = [
        '.promotion-labels-wrapper-to-remove',
        '.promotion-label-left',
        '.promotion-label-right',
        '.promotion-label-holder',
        '.promotion-label-buy-this-template',
        '.promotion-label-all-templates',
        '.w-webflow-badge',
        'body > a.w-webflow-badge',
        'a[class*="w-webflow-badge"]',
        'a[href*="webflow.com"][class*="webflow"]'
      ];
      const removePromotions = () => {
        selectors.forEach((selector) => {
          document.querySelectorAll(selector).forEach((element) => element.remove());
        });
      };
      removePromotions();
      document.addEventListener('DOMContentLoaded', removePromotions);
      window.addEventListener('load', removePromotions);
      new MutationObserver(removePromotions).observe(document.documentElement, {
        childList: true,
        subtree: true
      });
      let attempts = 0;
      const interval = window.setInterval(() => {
        removePromotions();
        attempts += 1;
        if (attempts > 40) window.clearInterval(interval);
      }, 250);
    })();
  </script>
`;

const copyButtonScript = `
  <script>
    (() => {
      const copyText = (value) => {
        if (navigator.clipboard && window.isSecureContext) {
          return navigator.clipboard.writeText(value);
        }

        const textarea = document.createElement('textarea');
        textarea.value = value;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'fixed';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        textarea.remove();
        return Promise.resolve();
      };

      const bindCopyButtons = () => {
        document.querySelectorAll('[data-copy-value]:not([data-copy-bound])').forEach((button) => {
          button.setAttribute('data-copy-bound', 'true');
          button.addEventListener('click', () => {
            const value = button.getAttribute('data-copy-value') || '';
            const label = button.getAttribute('data-copy-label') || button.textContent || 'Copy';
            const copiedLabel = button.getAttribute('data-copied-label') || 'Copied';
            const isIconOnly = button.hasAttribute('data-copy-icon-only');
            if (isIconOnly) {
              button.classList.add('is-copied');
              button.setAttribute('aria-label', copiedLabel);
              button.setAttribute('title', copiedLabel);
            } else {
              button.textContent = copiedLabel;
            }
            copyText(value).catch(() => {});
            window.setTimeout(() => {
              if (isIconOnly) {
                button.classList.remove('is-copied');
                button.setAttribute('aria-label', label);
                button.setAttribute('title', label);
              } else {
                button.textContent = label;
              }
            }, 3000);
          });
        });
      };

      const togglePhonePanel = (button) => {
        const panel = document.getElementById(button.getAttribute('aria-controls') || '');
        if (!panel) return;
        const isOpen = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!isOpen));
        panel.hidden = isOpen;
      };

      const bindPhoneToggles = () => {
        document.querySelectorAll('[data-phone-toggle]:not([data-phone-toggle-bound])').forEach((button) => {
          button.setAttribute('data-phone-toggle-bound', 'true');
        });

        if (!document.documentElement.hasAttribute('data-phone-toggle-delegated')) {
          document.documentElement.setAttribute('data-phone-toggle-delegated', 'true');
          document.addEventListener('click', (event) => {
            const button = event.target && event.target.closest
              ? event.target.closest('[data-phone-toggle]')
              : null;
            if (!button) return;
            event.preventDefault();
            togglePhonePanel(button);
          }, true);
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          bindCopyButtons();
          bindPhoneToggles();
        });
      } else {
        bindCopyButtons();
        bindPhoneToggles();
      }
    })();
  </script>
`;

const parseAttrs = (attrs: string) => {
  const parsed: Record<string, string | boolean> = {};
  const attrPattern = /([\w:-]+)(?:=(?:"([^"]*)"|'([^']*)'|([^\s>]+)))?/g;
  for (const match of attrs.matchAll(attrPattern)) {
    parsed[match[1]] = match[2] ?? match[3] ?? match[4] ?? true;
  }
  return parsed;
};
