---
interface Props {
  html: string;
}

const { html } = Astro.props;

const rawHead = html.match(/<head[^>]*>([\s\S]*?)<\/head>/i)?.[1] ?? '';
const rawBody = html.match(/<body[^>]*>([\s\S]*?)<\/body>/i)?.[1] ?? html;
const htmlAttrs = html.match(/<html\s+([^>]*)>/i)?.[1] ?? 'lang="en"';
const bodyAttrs = html.match(/<body\s*([^>]*)>/i)?.[1] ?? '';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { href: '/home', label: 'Home' },
  { href: '/about-us', label: 'About Us' },
  { href: '/our-business', label: 'Our Business' },
  { href: '/product-services', label: 'Product & Services' },
  { href: '/corporate-governance', label: 'Corporate Governance' },
  { href: '/announcement-resources', label: 'Announcement & Resources' },
];

const pageTitles: Record<string, string> = {
  '/home': 'Green Force',
  '/about-us': 'About Us | Green Force',
  '/our-business': 'Our Business | Green Force',
  '/product-services': 'Product & Services | Green Force',
  '/corporate-governance': 'Corporate Governance | Green Force',
  '/announcement-resources': 'Announcement & Resources | Green Force',
  '/contact-us': 'Contact Us | Green Force',
};

const applyGreenforceHead = (source: string) => {
  const title = pageTitles[currentPath];
  if (!title) return source;

  return source
    .replace(/<title>[\s\S]*?<\/title>/i, `<title>${title}</title>`)
    .replace(/<meta content="[^"]*" property="og:title"\/>/i, `<meta content="${title}" property="og:title"/>`)
    .replace(/<meta content="[^"]*" name="twitter:title"\/>/i, `<meta content="${title}" name="twitter:title"/>`);
};

const head = applyGreenforceHead(rawHead);

const brandLockup = (imageClass = 'logo') =>
  `<span class="greenforce-brand-lockup"><img src="/images/force.png" loading="lazy" alt="" height="30" class="${imageClass} greenforce-brand-icon"/><span class="greenforce-brand-text">Green Force</span></span>`;

const findMatchingNavEnd = (source: string, openStart: number) => {
  const tagPattern = /<\/?nav\b[^>]*>/gi;
  tagPattern.lastIndex = openStart;
  let depth = 0;

  for (const match of source.matchAll(tagPattern)) {
    const tag = match[0];
    if (tag.startsWith('</')) {
      depth -= 1;
      if (depth === 0) {
        return match.index + tag.length;
      }
    } else {
      depth += 1;
    }
  }

  return -1;
};

const applyGreenforceNavigation = (source: string) => {
  const navOpen = '<nav role="navigation" class="nav-menu w-nav-menu">';
  const start = source.indexOf(navOpen);
  if (start === -1) return source;

  const end = findMatchingNavEnd(source, start);
  if (end === -1) return source;

  const links = navItems
    .map((item) => {
      const isCurrent = currentPath === item.href;
      const className = `nav-link w-nav-link${isCurrent ? ' w--current' : ''}`;
      const ariaCurrent = isCurrent ? ' aria-current="page"' : '';
      return `<a href="${item.href}"${ariaCurrent} class="${className}">${item.label}</a>`;
    })
    .join('');

  const replacement = `${navOpen}<div class="tablet-menu"><a href="/home" class="brand-tablet w-nav-brand" aria-label="Green Force home">${brandLockup()}</a><div class="close-menu-button w-nav-button"><img src="https://cdn.prod.website-files.com/678918d2a9f3b2f0e792df83/678918d2a9f3b2f0e792e126_close-btn.svg" loading="lazy" alt="icon" class="nav-close-icon"/></div></div><div class="menu-wrap">${links}<div class="button-wrapper nav-style"><a data-w-id="8b9cd930-7584-d0db-6f84-b8a9d8b46370" href="/contact-us" class="primary-button-arrow-white w-inline-block"><div class="button-arrow-text">Contact Us</div><div class="arrow-wrapper dark"><img loading="lazy" src="https://cdn.prod.website-files.com/678918d2a9f3b2f0e792df83/678fcb2c1233901668561f0e_arrow-white.svg" alt="icon" class="arrow-icon"/></div></a></div></div></nav>`;

  return `${source.slice(0, start)}${replacement}${source.slice(end)}`;
};

const renameInternalRoutes = (source: string) =>
  source
    .replaceAll('href="/home-1"', 'href="/home"')
    .replaceAll('href="/loan-programs-1"', 'href="/our-business"')
    .replaceAll('href="/loan-programs-3"', 'href="/product-services"')
    .replaceAll('href="/faq"', 'href="/corporate-governance"')
    .replaceAll('href="/blog-1"', 'href="/announcement-resources"');

const replaceLoanlyLogoWordmark = (source: string) =>
  source
    .replace(
      /<img\b(?=[^>]*\bclass="logo")(?=[^>]*(?:loanly-logo-white-v2\.svg|green-force-logo-white-wordmark\.(?:png|svg)))[^>]*>/g,
      brandLockup()
    )
