      /<img\b(?=[^>]*\bclass="footer-logo")(?=[^>]*(?:loanly-logo-white-v2\.svg|green-force-logo-white-wordmark\.(?:png|svg)))[^>]*>/g,
      brandLockup('footer-logo')
    )
    .replaceAll('alt="logo"', 'alt="Green Force"');

